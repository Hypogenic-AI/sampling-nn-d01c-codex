{"type":"item.started","item":{"id":"item_85","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - <<'PY'\nfrom pathlib import Path\nimport json\nimport numpy as np\nimport pandas as pd\nimport torch\n\nfrom src.sampling_nn_experiment import (\n    ExperimentConfig,\n    SmallCNN,\n    evaluate_method,\n    get_device,\n    model_checkpoint_path,\n    prepare_data,\n    set_seed,\n)\n\nrequired = [\n    'REPORT.md', 'README.md', 'planning.md', 'CODE_WALKTHROUGH.md',\n    'src/sampling_nn_experiment.py', 'results/metrics_raw.csv',\n    'results/metrics_summary.csv', 'results/statistical_tests.csv',\n    'results/data_metadata.csv', 'results/environment.json',\n    'figures/accuracy_primary.png', 'figures/ece_primary.png',\n    'figures/nll_primary.png', 'figures/accuracy_sample_sweep.png',\n    'figures/entropy_sample_sweep.png', 'figures/variance_sample_sweep.png',\n    'figures/training_curves.png',\n]\nmissing = [p for p in required if not Path(p).exists()]\nassert not missing, f'Missing outputs: {missing}'\nmetrics = pd.read_csv('results/metrics_raw.csv')\nsummary = pd.read_csv('results/metrics_summary.csv')\ntests = pd.read_csv('results/statistical_tests.csv')\nassert len(metrics) == 102, len(metrics)\nassert len(summary) == 34, len(summary)\nassert len(tests) == 40, len(tests)\nmetric_cols = ['accuracy','nll','ece','brier','entropy','prob_variance']\nassert not metrics[metric_cols].isna().any().any()\nassert ((metrics['accuracy'] >= 0) & (metrics['accuracy'] <= 1)).all()\nassert (metrics['nll'] >= 0).all()\nassert ((metrics['ece'] >= 0) & (metrics['ece'] <= 1)).all()\n\ncfg = ExperimentConfig()\ndevice = get_device()\n_, _, test_loader, _ = prepare_data('mnist', 42, cfg)\nckpt = torch.load(model_checkpoint_path('mnist', 42, 'deterministic'), map_location=device)\nmodel = SmallCNN(hidden_dim=cfg.hidden_dim, dropout_p=0.0).to(device)\nmodel.load_state_dict(ckpt['model_state_dict'])\nset_seed(2026)\nfirst, _, _ = evalu