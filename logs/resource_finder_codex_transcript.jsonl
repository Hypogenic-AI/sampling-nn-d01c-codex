{"type":"item.started","item":{"id":"item_70","type":"command_execution","command":"/bin/bash -lc \"pwd && curl -L --fail --retry 3 -o papers/2017_alemi_deep_variational_information_bottleneck.pdf https://arxiv.org/pdf/1612.00410 && curl -L --fail --retry 3 -o papers/2018_dai_compressing_networks_vib.pdf https://arxiv.org/pdf/1802.10399 && source .venv/bin/activate && python - <<'PY'\nfrom pathlib import Path\nfrom pypdf import PdfReader\nfor p in sorted(Path('papers').glob('2017_alemi*.pdf')) + sorted(Path('papers').glob('2018_dai*.pdf')):\n    r=PdfReader(str(p)); print(p.name, p.stat().st_size, len(r.pages), 'pages')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_70","type":"command_execution","command":"/bin/bash -lc \"pwd && curl -L --fail --retry 3 -o papers/2017_alemi_deep_variational_information_bottleneck.pdf https://arxiv.org/pdf/1612.00410 && curl -L --fail --retry 3 -o papers/2018_dai_compressing_networks_vib.pdf https://arxiv.org/pdf/1802.10399 && source .venv/bin/activate && python - <<'PY'\nfrom pathlib import Path\nfrom pypdf import PdfReader\nfor p in sorted(Path('papers').glob('2017_alemi*.pdf')) + sorted(Path('papers').glob('2018_dai*.pdf')):\n    r=PdfReader(str(p)); print(p.name, p.stat().st_size, len(r.pages), 'pages')\nPY\"","aggregated_output":"\r100 8656k  100 8656k    0     0  49.4M      0 --:--:-- --:--:-- --:--:-- 49.7M\n  % Total    % Received % Xferd  Average Speed   Time    Time     Time  Current\n                                 Dload  Upload   Total   Spent    Left  Speed\n\r  0     0    0     0    0     0      0      0 --:--:-- --:--:-- --:--:--     0\r100  556k  100  556k    0     0  5758k      0 --:--:-- --:--:-- --:--:-- 5792k\n2017_alemi_deep_variational_information_bottleneck.pdf 8864469 19 pages\n2018_dai_compressing_networks_vib.pdf 569416 27 pages\n","exit_code":0,"status":"completed"}}
