{"type":"item.started","item":{"id":"item_79","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - <<'PY'\nfrom datasets import load_dataset\nfrom pathlib import Path\nimport json\n\ncandidates = [\n    ('mnist', ['ylecun/mnist', 'mnist']),\n    ('fashion_mnist', ['zalando-datasets/fashion_mnist', 'fashion_mnist']),\n    ('cifar10', ['uoft-cs/cifar10', 'cifar10']),\n    ('cifar100', ['uoft-cs/cifar100', 'cifar100']),\n]\nroot = Path('datasets')\nsummary = {}\nfor local_name, names in candidates:\n    print(f'\\\\n=== {local_name} ===')\n    ds = None\n    used = None\n    last_err = None\n    for name in names:\n        try:\n            print(f'trying {name}')\n            ds = load_dataset(name)\n            used = name\n            break\n        except Exception as e:\n            print(f'failed {name}: {e}')\n            last_err = e\n    if ds is None:\n        raise RuntimeError(f'Could not load {local_name}: {last_err}')\n    out = root / local_name\n    ds.save_to_disk(str(out))\n    split_counts = {split: len(ds[split]) for split in ds.keys()}\n    print('source', used, 'splits', split_counts)\n    sample_dir = out / 'samples'\n    sample_dir.mkdir(parents=True, exist_ok=True)\n    examples = []\n    first_split = next(iter(ds.keys()))\n    for i in range(min(5, len(ds[first_split]))):\n        row = ds[first_split][i]\n        rec = {}\n        for k, v in row.items():\n            if k in ('image', 'img'):\n                rec[k] = '<PIL image omitted>'\n            else:\n                rec[k] = v.item() if hasattr(v, 'item') else v\n        examples.append(rec)\n    with open(sample_dir / 'examples.json', 'w') as f:\n        json.dump({'source': used, 'split': first_split, 'examples': examples}, f, indent=2)\n    summary[local_name] = {'source': used, 'splits': split_counts, 'location': str(out)}\nwith open(root / 'dataset_summary.json', 'w') as f:\n    json.dump(summary, f, indent=2)\nprint('\\\\nSUMMARY')\nprint(json.dumps(summary, indent=2))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
